{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Plyra",
  "colors": {
    "primary": "#2dd4bf",
    "light": "#2dd4bf",
    "dark": "#1a9e8f"
  },
  "background": {
    "color": {
      "dark": "#0a0e13"
    }
  },
  "appearance": {
    "default": "dark"
  },
  "favicon": "/images/favicon.svg",
  "logo": {
    "dark": "/images/logo-dark.svg",
    "light": "/images/logo-light.svg",
    "href": "https://docs.plyra.dev"
  },
  "navbar": {
    "links": [
      { "label": "GitHub", "href": "https://github.com/plyraAI" },
      { "label": "plyra.dev", "href": "https://plyra.dev" }
    ],
    "primary": {
      "type": "button",
      "label": "Get started",
      "href": "/guard/quickstart"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Guard",
        "groups": [
          {
            "group": "Getting started",
            "pages": ["index", "guard/overview", "guard/quickstart"]
          },
          {
            "group": "Core concepts",
            "pages": ["guard/policy", "guard/exporters", "guard/dashboard"]
          },
          {
            "group": "Integrations",
            "pages": ["guard/frameworks"]
          },
          {
            "group": "Reference",
            "pages": ["guard/api-reference"]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "href": "https://github.com/plyraAI/plyra-guard",
          "icon": "github"
        },
        {
          "anchor": "PyPI",
          "href": "https://pypi.org/project/plyra-guard",
          "icon": "box"
        }
      ]
    }
  },
  "contextual": {
    "options": ["copy", "view", "claude", "cursor"]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/plyraAI",
      "github": "https://github.com/plyraAI"
    }
  }
}
